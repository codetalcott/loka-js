From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Wm Talcott <32972881+codetalcott@users.noreply.github.com>
Subject: [PATCH] paxi: swap-strategy hook for localized morph aliases

REFERENCE PATCH — this is documentation of the diff between loka-js's
patched paxi.js and bigskysoftware/paxi@c9b194e. loka-js ships the
patched copy directly; this file is NOT a PR submission. fixiproject
is deliberately minimalist; we are an alternate distribution serving a
different audience. If a maintainer ever wants the hook upstream, this
patch is ready to apply.

Replaces the hardcoded "morph" string-equality test with a defaulted
predicate on window.paxi:

  - isSwap(s) -> boolean   (default: s === "morph")

Behavior is identical to upstream when window.paxi is unset (the ??=
default reproduces the original literal comparison). Net size: ~30
bytes minified.

Enables loka-js to register localized swap-strategy names (e.g.,
"morfar" in Spanish) that resolve to the canonical morph
implementation, without paxi needing to know the language vocabulary.

See https://github.com/codetalcott/loka-js for the language-module
ecosystem this is part of.
---
 paxi.js | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/paxi.js b/paxi.js
--- a/paxi.js
+++ b/paxi.js
@@ -1,4 +1,6 @@
 (()=>{
+	let p = window.paxi ??= {}
+	let isMorph = p.isSwap ??= (s)=>s === "morph"
 	let mx = (o, n, ids)=>{
 		if (o.nodeType !== n.nodeType || o.nodeName !== n.nodeName){
 			n.querySelectorAll?.("[id]").forEach((ne)=>{
@@ -38,6 +40,6 @@
 		mx(target, t.content.firstElementChild, ids)
 	}
 	document.addEventListener("fx:config", (e)=>{
-		if (e.detail.cfg.swap === "morph") e.detail.cfg.swap = (cfg)=>morph(cfg.target, cfg.text)
+		if (isMorph(e.detail.cfg.swap)) e.detail.cfg.swap = (cfg)=>morph(cfg.target, cfg.text)
 	})
 })()
